# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=lessonplanner
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lessonplanner

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: https://<your-domain>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-domain.com

ENVIRONMENT=production

# ── Deployment ────────────────────────────────────────────────────────────────
# Your domain pointing to the homelab (via Cloudflare, DuckDNS, etc.)
DOMAIN=your-domain.com

# GitHub Container Registry image tag (set automatically by CI)
IMAGE_TAG=latest

# GitHub repo in org/repo format (used to construct GHCR image paths)
GITHUB_REPOSITORY=your-github-username/teacher-lesson-planner
