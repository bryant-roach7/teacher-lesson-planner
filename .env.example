# Postgres
POSTGRES_USER=lessonplanner
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lessonplanner

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: https://<your-domain>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# App
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Comma-separated list of allowed CORS origins (your public domain, managed by NPM)
ALLOWED_ORIGINS=https://your-domain.com

ENVIRONMENT=production

# Deployment
# GitHub Container Registry image tag (set automatically by CI)
IMAGE_TAG=latest

# GitHub repo in org/repo format (used to construct GHCR image paths)
GITHUB_REPOSITORY=your-github-username/teacher-lesson-planner

# Host ports - adjust if these conflict with other services on the homelab.
# Nginx Proxy Manager proxy hosts should point to these ports on the host.
# 8081 -> FastAPI backend (internal port 8000)
# 8082 -> React frontend (internal port 80)
BACKEND_HOST_PORT=8081
FRONTEND_HOST_PORT=8082
