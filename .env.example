# Postgres
POSTGRES_USER=lessonplanner
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lessonplanner

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Add both redirect URIs to your OAuth client in Google Cloud Console:
#   http://localhost:8000/auth/google/callback          (dev)
#   https://your-domain.com/auth/google/callback        (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Set these per environment ---
# Development (.env on local machine):
#   GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
#   FRONTEND_URL=http://localhost:4173
#   ENVIRONMENT=development
#
# Production (.env on homelab):
#   GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback
#   FRONTEND_URL=https://your-domain.com
#   ENVIRONMENT=production
GOOGLE_REDIRECT_URI=
FRONTEND_URL=
ENVIRONMENT=development

# Anthropic
ANTHROPIC_API_KEY=

# App
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Comma-separated list of allowed CORS origins (used in production)
ALLOWED_ORIGINS=https://your-domain.com

# Deployment
# GitHub Container Registry image tag (set automatically by CI)
IMAGE_TAG=latest

# GitHub repo in org/repo format (used to construct GHCR image paths)
GITHUB_REPOSITORY=your-github-username/teacher-lesson-planner

# Host ports - adjust if these conflict with other services on the homelab.
# Nginx Proxy Manager proxy hosts should point to these ports on the host.
# 8081 -> FastAPI backend (internal port 8000)
# 8082 -> React frontend (internal port 80)
BACKEND_HOST_PORT=8081
FRONTEND_HOST_PORT=8082
